<Page
    x:Class="MEmarket_UWP.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MEmarket_UWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="LayoutRoot">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="16,16,16,24">

                <!-- Шапка страницы -->

                <!-- БЛОК ВЫБОР РЕДАКЦИИ (Кликабельный баннер) -->
                <Grid x:Name="FeaturedBanner" 
                      Margin="0,0,0,16" 
                      Height="160" 
                      Tapped="FeaturedBanner_Tapped"
                      Background="{ThemeResource SystemControlHighlightListAccentLowBrush}" >
                    <Grid.Clip>
                        <RectangleGeometry Rect="0,0,1000,160"/>
                    </Grid.Clip>
                    <Grid Padding="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="РЕКОМЕНДУЕМ" FontSize="11" FontWeight="Bold" Opacity="0.6" Margin="0,0,0,4"/>
                            <TextBlock x:Name="FeaturedAppName" Text="" FontSize="24" FontWeight="SemiBold" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="FeaturedAppSummary" Text="" FontSize="13" Opacity="0.8" TextWrapping="Wrap" MaxLines="2" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Иконка рекомендуемого приложения справа -->
                        <Image x:Name="FeaturedAppIcon" Grid.Column="1" Width="70" Height="70" VerticalAlignment="Center" Margin="12,0,0,0" Stretch="Uniform"/>
                    </Grid>
                </Grid>

                <!-- Состояние -->
                <Border BorderThickness="2" BorderBrush="{ThemeResource SystemControlHighlightListAccentLowBrush}" Padding="12" Margin="0,0,0,0" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="&#xE12B;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Состояние" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="RepoStatusText" 
                       Text="" 
                       FontSize="11" 
                       Opacity="0.6" 
                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Системный индикатор загрузки всей домашней страницы -->
        <ProgressRing x:Name="LoadingRing" 
                      IsActive="True" 
                      HorizontalAlignment="Center" 
                      VerticalAlignment="Center" 
                      Width="50" Height="50"/>
    </Grid>
</Page>
