<Page
    x:Class="MEmarket_UWP.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MEmarket_UWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{ThemeResource SystemControlBackgroundChromeMediumBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="HamburgerButton" 
                    FontFamily="Segoe MDL2 Assets" 
                    Content="&#xE700;" 
                    Width="48" Height="48" 
                    Background="Transparent"
                    Click="HamburgerButton_Click" FontSize="20"/>
            <TextBlock x:Name="TitleTextBlock" 
                       Grid.Column="1" 
                       Text="MEmarket" 
                       FontSize="18" 
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" 
                       Margin="12,0,0,0"/>
        </Grid>

        <SplitView x:Name="RootSplitView" 
                   Grid.Row="1" 
                   DisplayMode="Overlay" 
                   OpenPaneLength="260" 
                   IsPaneOpen="False">
            <SplitView.Pane>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                        <StackPanel>
                            <!-- Системные разделы -->
                            <ListView x:Name="SystemNavigationListView" 
                                      IsItemClickEnabled="True" 
                                      ItemClick="SystemNavigationListView_ItemClick"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ItemContainerStyle="{StaticResource NavigationListViewItemStyle}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="48">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Name}" 
                                                       FontSize="16" 
                                                       VerticalAlignment="Center" 
                                                       Margin="8,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>


                            <Border Height="1" Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3" Margin="16,8,16,8"/>
                            
                            <!-- Категории -->
                            <ListView x:Name="CategoriesNavigationListView" 
                                      IsItemClickEnabled="True" 
                                      ItemClick="CategoriesNavigationListView_ItemClick"
                                      ScrollViewer.VerticalScrollMode="Disabled"
                                      ItemContainerStyle="{StaticResource NavigationListViewItemStyle}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="48">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding IconGlyph}"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Name}" 
                                                       FontSize="16" 
                                                       VerticalAlignment="Center" 
                                                       Margin="8,0,0,0"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Настройки -->
                    <ListView x:Name="SettingsNavigationListView" Grid.Row="1" IsItemClickEnabled="True" ItemClick="SettingsNavigationListView_ItemClick" ScrollViewer.VerticalScrollMode="Disabled"
                              ItemContainerStyle="{StaticResource NavigationListViewItemStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="48">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding IconGlyph}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="20"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding Name}" 
                                               FontSize="16" 
                                               VerticalAlignment="Center" 
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </SplitView.Pane>

            <!-- Контент фрейм -->
            <SplitView.Content>
                <Grid>
                    <Frame x:Name="ContentFrame" x:FieldModifier="public" Navigated="ContentFrame_Navigated"/>
                    <ProgressRing x:Name="LoadingRing" 
                                  IsActive="True" 
                                  HorizontalAlignment="Center" 
                                  VerticalAlignment="Center" 
                                  Height="50" Width="50"/>
                </Grid>
            </SplitView.Content>
        </SplitView>
    </Grid>
</Page>
