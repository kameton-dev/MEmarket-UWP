<Page
    x:Class="MEmarket_UWP.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MEmarket_UWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" FontFamily="Segoe UI Semilight">
    

    <Grid x:Name="LayoutRoot">
        <Pivot>
            <PivotItem Header="Основные">
                <StackPanel>
                    <TextBlock Text="Показывать приложения:" Style="{ThemeResource BodyTextBlockStyle}" Margin="0,8,0,8" FontSize="16"/>
                    <CheckBox x:Name="SilverlightCheckBox" Content="Silverlight [WP8.0-8.1]" HorizontalAlignment="Stretch" Margin="0,0,0,0" VerticalAlignment="Stretch" Checked="AppTypeFilter_Changed" Unchecked="AppTypeFilter_Changed"/>
                    <CheckBox x:Name="WinRTCheckBox" Content="WinRT [WP8.1] (Подходит для W10M)" HorizontalAlignment="Stretch" Margin="0,0,0,0" VerticalAlignment="Stretch" Checked="AppTypeFilter_Changed" Unchecked="AppTypeFilter_Changed"/>
                    <CheckBox x:Name="UwpCheckBox" Content="UWP [W10M]" HorizontalAlignment="Stretch" Margin="0,0,0,0.1" VerticalAlignment="Stretch" Checked="AppTypeFilter_Changed" Unchecked="AppTypeFilter_Changed"/>

                    <ToggleSwitch x:Name="BackgroundUpdateToggle" Header="Проверка обновлений в фоне при старте заходе в приложение" HorizontalAlignment="Stretch" Margin="0,8,0,0" VerticalAlignment="Stretch" Toggled="BackgroundUpdateToggle_Toggled"/>
                    
                    <Border Height="1" Background="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" Opacity="0.3" Margin="8,16,8,16"/>

                    <Button Content="Очистить кэш" HorizontalAlignment="Left" VerticalAlignment="Top" Click="ClearCacheButton_Click"/>
                </StackPanel>
            </PivotItem>
            
            <PivotItem Header="Репозитории" Margin="0,0,0,0">
                <Grid>
                    <ScrollViewer>
                        <StackPanel>
                            <Grid Margin="12,8,12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="RepositoryUrlTextBox" 
                                 PlaceholderText="Введите URL репозитория..."
                                 Grid.Column="0"
                                 Margin="0,0,9.5,0"/>
                                <Button x:Name="AddRepositoryButton"
                                Grid.Column="1"
                                Content="Добавить"
                                Click="AddRepositoryButton_Click"
                                MinWidth="100"/>
                            </Grid>

                            <ListView x:Name="RepositoriesListBox"
                             Margin="0,0,0,16" Background="{x:Null}"
                             IsItemClickEnabled="True"
                             ItemClick="RepositoriesListBox_ItemClick">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding Name}" 
                                                   Style="{ThemeResource BodyTextBlockStyle}"
                                                   FontWeight="Bold" FontSize="16"/>
                                                <TextBlock Text="{Binding Creator}" 
                                                   Style="{ThemeResource CaptionTextBlockStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </PivotItem>

            <PivotItem Header="О программе">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,7.7,0,16">
                        <Border Background="{ThemeResource SystemControlBackgroundAccentBrush}" Margin="0,0,8,0" Padding="4,4,4,4">
                        <Image Source="/Assets/StoreLogo.png" Width="60" Height="60" HorizontalAlignment="Left" Margin="0,0,0,0"/>
                        </Border>
                        <TextBlock Text="MEmarket UWP" VerticalAlignment="Center" FontSize="20" FontFamily="Segoe UI Semilight"/>
                    </StackPanel>
                    <TextBlock Text="Версия 0.1.2.0 (Public Beta)" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="Данный клиент находится на этапе разработки. Возможны баги, зависания и микрофризы" Foreground="Red" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="© 2026 kameton.dev. Гойда ＼(°O°)／." Style="{ThemeResource BodyTextBlockStyle}" Opacity="0.6"/>
                </StackPanel>
            </PivotItem>
        </Pivot>
    </Grid>

</Page>
