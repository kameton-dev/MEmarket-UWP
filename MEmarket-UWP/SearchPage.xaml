<Page
    x:Class="MEmarket_UWP.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MEmarket_UWP"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid x:Name="LayoutRoot">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="SearchTextBox" 
                 PlaceholderText="Поиск приложений"
                 Grid.Row="0"
                 Margin="12,8,12,8"
                 TextChanged="SearchTextBox_TextChanged"
                 KeyDown="SearchTextBox_KeyDown" InputScope="Search"/>

        <ListView x:Name="SearchResultsList"
                  Grid.Row="1"
                  Margin="0,0,0,0"
                  IsItemClickEnabled="True"
                  ItemClick="SearchResultsList_ItemClick">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,6,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="{Binding Icon}" 
                               Width="50" 
                               Height="50" 
                               Margin="0,0,8,0"
                               ImageFailed="IconImage_ImageFailed"/>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding Name}" FontSize="18" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Summary}" Style="{ThemeResource BodyTextBlockStyle}" TextWrapping="Wrap" Opacity="0.8" MaxLines="2" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="NoResultsText" 
                   Grid.Row="1"
                   Text="Введите запрос для поиска"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   Opacity="0.5"/>
    </Grid>
</Page>
